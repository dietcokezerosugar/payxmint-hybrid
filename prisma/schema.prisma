generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model User {
  id         String    @id @default(cuid())
  email      String    @unique
  password   String
  name       String?
  role       String    @default("MERCHANT") // ADMIN, MERCHANT, AGENT, STAFF
  merchant   Merchant? @relation(fields: [merchantId], references: [id])
  merchantId String?
  createdAt  DateTime  @default(now())
}

model Merchant {
  id               String           @id @default(cuid())
  name             String
  businessName     String?
  email            String           @unique
  address          String?
  phone            String?
  status           String           @default("PENDING") // PENDING, ACTIVE, SUSPENDED
  walletBalance    Float            @default(0)
  commissionRate   Float            @default(0)
  
  // Whitelist & Integration
  ipWhitelist      String?          // Comma separated IPs
  webhookWhitelist String?          // Optional: restricted webhook origins
  webhookUrl       String?          
  redirectUrl      String?          
  
  // Telegram Alerts
  telegramBotToken String?
  telegramChatId   String?
  
  // Relations
  users            User[]
  apiKeys          ApiKey[]
  paymentIntents   PaymentIntent[]
  gpayAccounts     GooglePayAccount[]
  ledgerEntries    WalletLedger[]
  agent            Agent?           @relation(fields: [agentId], references: [id])
  agentId          String?
  
  apiAccessStatus  String           @default("NOT_REQUESTED") // NOT_REQUESTED, PENDING, APPROVED
  
  createdAt        DateTime         @default(now())
  updatedAt        DateTime         @updatedAt
}

model Agent {
  id             String     @id @default(cuid())
  name           String
  email          String     @unique
  commissionRate Float      @default(0)
  merchants      Merchant[]
  createdAt      DateTime   @default(now())
}

model WalletLedger {
  id            String   @id @default(cuid())
  merchantId    String
  merchant      Merchant @relation(fields: [merchantId], references: [id])
  type          String   // CREDIT, DEBIT
  amount        Float
  description   String?
  balanceAfter  Float
  referenceType String?  // TRANSACTION, RECHARGE, PAYOUT
  referenceId   String?
  createdAt     DateTime @default(now())
}

model ApiKey {
  id           String          @id @default(cuid())
  key          String          @unique
  merchantId   String
  merchant     Merchant        @relation(fields: [merchantId], references: [id])
  monthlyLimit Float           @default(100000)
  usedAmount   Float           @default(0)
  isBlocked    Boolean         @default(false)
  createdAt    DateTime        @default(now())
  paymentIntents PaymentIntent[]
}

model PaymentIntent {
  id               String      @id @default(cuid())
  merchantId       String
  merchant         Merchant    @relation(fields: [merchantId], references: [id])
  apiKeyId         String
  apiKey           ApiKey      @relation(fields: [apiKeyId], references: [id])
  amount           Float
  status           String      @default("PENDING") // PENDING, SUCCESS, FAILED, EXPIRED
  referenceId      String      @unique // order_id from merchant
  customerMobile   String?
  customerEmail    String?
  redirectUrl      String?
  merchantName     String?
  upiDeepLink      String?
  qrData           String?
  paymentToken     String?     @unique // for hosted pages
  payerName        String?
  payerUpiId       String?
  transactionId    String?     @unique // linked after verification
  transaction      Transaction? @relation(fields: [transactionId], references: [id])
  
  // Auditing & Manual Flow
  isManualApproval Boolean     @default(false)
  approvalIp       String?     
  
  createdAt        DateTime    @default(now())
  expireAt         DateTime?
  updatedAt        DateTime    @updatedAt
}

model Transaction {
  id            String         @id @default(cuid())
  externalId    String         @unique // merchantTransactionId from GPay
  utr           String?
  amount        Float
  payerName     String?
  payerUpiId    String?
  note          String?
  timestamp     DateTime       @default(now())
  paymentIntent PaymentIntent?
}

model PaymentLink {
  id           String   @id @default(cuid())
  merchantId   String
  title        String
  amount       Float
  description  String?
  slug         String   @unique
  apiKeyId     String
  isActive     Boolean  @default(true)
  createdAt    DateTime @default(now())
}

model GooglePayAccount {
  id             String    @id @default(cuid())
  merchantId     String
  merchant       Merchant  @relation(fields: [merchantId], references: [id])
  name           String
  email          String
  upiId          String
  reportId       String?
  status         String    @default("ACTIVE")
  lastSync       DateTime?
  
  // Advanced SaaS Limits
  minTicket      Float     @default(0)
  maxTicket      Float     @default(1000000)
  dailyLimit     Float     @default(0)
  weeklyLimit    Float     @default(0)
  monthlyLimit   Float     @default(0)
  
  currentDaily   Float     @default(0)
  currentWeekly  Float     @default(0)
  currentMonthly Float     @default(0)
  
  createdAt      DateTime  @default(now())
}

model AuditLog {
  id          String   @id @default(cuid())
  userId      String
  action      String
  metadata    String?  // JSON string
  timestamp   DateTime @default(now())
}

model ApiLog {
  id        String   @id @default(cuid())
  merchantId String?
  level     String   @default("INFO") // INFO, SUCCESS, WARNING, ERROR, CRITICAL
  message   String
  metadata  String?  // JSON string
  timestamp DateTime @default(now())
}

